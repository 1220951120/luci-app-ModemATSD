#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

TOKEN_FILE="/usr/bin/smstrun-AK68.conf"
LOCK_FILE="/tmp/smstrun-AK68.lock"

has_token() {
	[ -f "$TOKEN_FILE" ] && grep -q '[^[:space:]]' "$TOKEN_FILE"
}

stop_legacy_forwarder() {
	local pids
	pids="$(pgrep -f '^python3 /usr/bin/smstrun-AK68.py$'; pgrep -f '^/usr/bin/python3 /usr/bin/smstrun-AK68.py$')"
	[ -z "$pids" ] || kill $pids 2>/dev/null
}

start_service() {
	has_token || return 0

	stop_legacy_forwarder
	rm -f "$LOCK_FILE"
	procd_open_instance forwarder
	procd_set_param command /usr/bin/python3 /usr/bin/smstrun-AK68.py
	procd_set_param env PYTHONUNBUFFERED=1
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	stop_legacy_forwarder
}

service_stopped() {
	rm -f "$LOCK_FILE"
}

reload_service() {
	stop
	start
}
